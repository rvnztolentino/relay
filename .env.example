# Copy this file to .env and fill in real values:  cp .env.example .env
# A single .env at the repo root is read by BOTH Docker Compose and the host API.

# --- PostgreSQL (consumed by Docker Compose AND the API) ---
POSTGRES_USER=relay
POSTGRES_PASSWORD=change_me
POSTGRES_DB=relay
PGHOST=localhost
PGPORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
PORT=3000

# Placeholder — first used in the auth branch (Phase 3). Use a long random string.
JWT_SECRET=change_me_long_random
